{
  "name": "wateringhub-card",
  "version": "0.0.41",
  "description": "Custom Home Assistant card for WateringHub",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/wateringhub-card.js --format=esm --minify",
    "watch": "esbuild src/index.ts --bundle --outfile=dist/wateringhub-card.js --format=esm --watch",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "lit": "^3.3.2",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "~5.8"
  },
  "license": "MIT"
}
