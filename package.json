{
  "name": "wateringhub-card",
  "version": "0.0.5",
  "description": "Custom Home Assistant card for WateringHub",
  "scripts": {
    "build": "esbuild src/wateringhub-card.ts --bundle --outfile=dist/wateringhub-card.js --format=esm --minify",
    "watch": "esbuild src/wateringhub-card.ts --bundle --outfile=dist/wateringhub-card.js --format=esm --watch",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "lit": "^3.3.2",
    "prettier": "^3.8.1"
  },
  "license": "MIT"
}
